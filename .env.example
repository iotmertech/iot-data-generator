# Copy this file to .env and fill in your broker details:
#   cp .env.example .env

# Target MQTT broker URL
# Plain TCP:  mqtt://broker.example.com:1883
# TLS:        mqtts://broker.example.com:8883
MQTT_BROKER=mqtt://broker.example.com:1883

# Topic template — {device_id} is replaced per device
MQTT_TOPIC=devices/{device_id}/telemetry

# --- Auth (leave blank if your broker has no auth) ---
# If set, switch docker-compose to use docker/mer.docker-auth.yaml
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Optional run tuning ---
# DEVICE_COUNT=5
# DEVICE_PREFIX=device
# TOTAL_MESSAGES=20
# INTERVAL_MS=1000
